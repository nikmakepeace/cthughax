{
  "version": "2.0.0",
  "tasks": [
    {
        "label": "CMake: configure",
        "type": "shell",
        "command": "cmake",
        "args": [
            "-S",
            "${workspaceFolder}",
            "-B",
            "${workspaceFolder}/build",
            "-DCMAKE_BUILD_TYPE=Debug",
            "-DCTH_BUILD_X11=OFF",
            "-DCTH_BUILD_SDL3=ON",
            "-DCTH_ENABLE_MINIAUDIO=ON",
            "-DCTH_ENABLE_PULSE=OFF",
            "-DCTH_BUILD_TESTS=ON",
            "-DCTH_BUILD_BENCHMARKS=OFF"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "problemMatcher": []
    },
    {
        "label": "CMake: build",
        "type": "shell",
        "command": "cmake",
        "args": [
            "--build",
            "${workspaceFolder}/build",
            "--parallel"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        }, 
        "dependsOn": "CMake: configure",
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "problemMatcher": "$msCompile"
    },
    {
        "label": "CMake: configure benchmarks",
        "type": "shell",
        "command": "cmake",
        "args": [
            "-S",
            "${workspaceFolder}",
            "-B",
            "${workspaceFolder}/build",
            "-DCMAKE_BUILD_TYPE=Debug",
            "-DCTH_BUILD_BENCHMARKS=ON"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "problemMatcher": []
    },
    {
        "label": "Benchmarks: build audio pipeline",
        "type": "shell",
        "command": "cmake",
        "args": [
            "--build",
            "${workspaceFolder}/build",
            "--target",
            "audio_pipeline_bench",
            "--parallel"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "dependsOn": "CMake: configure benchmarks",
        "problemMatcher": "$msCompile"
    },
    {
        "label": "Benchmarks: run audio pipeline report",
        "type": "shell",
        "command": "cmake",
        "args": [
            "--build",
            "${workspaceFolder}/build",
            "--target",
            "audio_pipeline_benchmark_report"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "dependsOn": "CMake: configure benchmarks",
        "problemMatcher": "$msCompile"
    },
    {
        "label": "Benchmarks: quick audio pipeline report",
        "type": "shell",
        "command": "python3",
        "args": [
            "${workspaceFolder}/tools/run_audio_pipeline_benchmarks.py",
            "--build-dir",
            "${workspaceFolder}/build",
            "--source-dir",
            "${workspaceFolder}",
            "--repetitions",
            "5",
            "--warmup-time",
            "0.05",
            "--benchmark-arg=--benchmark_min_time=0.03s"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "dependsOn": "Benchmarks: build audio pipeline",
        "problemMatcher": []
    },
    {
        "label": "CMake: clean",
        "type": "shell",
        "command": "cmake",
        "args": [
            "--build",
            "${workspaceFolder}/build",
            "--target",
            "clean"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "problemMatcher": "$msCompile"
    },
    {
        "label": "Run cthugha",
        "type": "shell",
        "command": "bash",
        "args": [
            "-lc",
            "exec \"${workspaceFolder}/build/src/cthugha\" ${input:cthughaArgs}"
        ],
        "options": {
            "cwd": "${workspaceFolder}"
        },
        "dependsOn": "CMake: build",
        "problemMatcher": []
    }
],
  "inputs": [
    {
      "id": "cthughaArgs",
      "type": "promptString",
      "description": "Optional arguments for cthugha",
      "default": ""
    }
  ]
}
